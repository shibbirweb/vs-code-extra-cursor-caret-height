{
  "name": "extra-cursor-caret-height",
  "displayName": "Extra Cursor Caret Height",
  "description": "Add extra cursor caret height for better visibility",
  "version": "1.3.0",
  "publisher": "shibbirweb",
  "packageManager": "pnpm@11.9.0",
  "license": "MIT",
  "author": {
    "name": "MD. Shibbir Ahmed",
    "email": "shibbirweb@gmail.com",
    "url": "https://shibbirweb.github.io"
  },
  "sponsor": {
    "url": "https://buymeacoffee.com/shibbirweb"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shibbirweb/vs-code-extra-cursor-caret-height"
  },
  "bugs": {
    "url": "https://github.com/shibbirweb/vs-code-extra-cursor-caret-height/issues"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "cursor",
    "caret",
    "height",
    "visibility",
    "accessibility"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:extra-cursor-caret-height.applyExtraHeight",
    "onCommand:extra-cursor-caret-height.resetExtraHeight"
  ],
  "main": "./out/extension.js",
  "icon": "icon.png",
  "contributes": {
    "commands": [
      {
        "command": "extra-cursor-caret-height.applyExtraHeight",
        "title": "Extra Cursor Caret Height: Apply Height"
      },
      {
        "command": "extra-cursor-caret-height.resetExtraHeight",
        "title": "Extra Cursor Caret Height: Reset Height"
      }
    ],
    "configuration": {
      "title": "Extra Cursor Caret Height",
      "properties": {
        "extraCursorCaretHeight.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable the extra caret (text cursor) height patch. When turned on, VS Code's workbench script is patched to `#extraCursorCaretHeight.height#`px; when off, the patch is removed. You will be prompted to **Reload Window** to see the change."
        },
        "extraCursorCaretHeight.height": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "markdownDescription": "Total extra caret (text cursor) height, in pixels. Applied only when `#extraCursorCaretHeight.enabled#` is on."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run check-types && pnpm run bundle",
    "compile": "tsc -p ./",
    "check-types": "tsc --noEmit -p ./",
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "pnpm vsce package --no-dependencies",
    "publish": "pnpm vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.25.1",
    "ovsx": "^1.0.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@vscode/sudo-prompt": "^9.3.2"
  }
}
